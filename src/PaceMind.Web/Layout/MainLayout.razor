@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeService Theme

<div class="flex min-h-screen">
    <NavMenu />
    <main class="min-w-0 flex-1">
        <div class="flex justify-end px-6 pt-4">
            <button @onclick="Theme.ToggleAsync"
                    class="rounded-lg border border-border px-3 py-1.5 text-xs text-muted transition hover:border-brand-500/40 hover:text-fg">
                @(Theme.Current == "dark" ? "Light mode" : "Dark mode")
            </button>
        </div>
        <div class="mx-auto max-w-6xl px-6 pb-8 pt-2">
            @Body
        </div>
    </main>
</div>

@code {
    protected override void OnInitialized() => Theme.Changed += StateHasChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await Theme.InitializeAsync();
    }

    public void Dispose() => Theme.Changed -= StateHasChanged;
}
