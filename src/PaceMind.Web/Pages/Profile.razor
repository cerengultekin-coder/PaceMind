@page "/profile"

<PageTitle>PaceMind — Profile</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight">Profile</h1>
    <p class="mt-1 text-slate-400">Your account and connected data sources.</p>
</div>

<div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
        <div class="flex items-center gap-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-500/20 text-xl font-bold text-brand-300">A</div>
            <div>
                <div class="font-semibold">Athlete</div>
                <div class="text-sm text-slate-400">signed in with Google</div>
            </div>
        </div>
        <button class="mt-6 w-full rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-300 transition hover:border-slate-600">
            Sign out
        </button>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 lg:col-span-2">
        <h3 class="font-semibold">Data sources</h3>
        <p class="mt-1 text-sm text-slate-400">Objective data gives the coach a second signal alongside how you felt.</p>

        <div class="mt-4 space-y-3">
            <div class="flex items-center justify-between rounded-xl border border-slate-800 bg-slate-950 p-4">
                <div class="flex items-center gap-3">
                    <div>
                        <div class="text-sm font-medium">GPX upload</div>
                        <div class="text-xs text-slate-400">Upload a session file to enrich adaptation.</div>
                    </div>
                </div>
                <button class="rounded-lg bg-brand-500 px-4 py-1.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400">
                    Upload
                </button>
            </div>

            <div class="flex items-center justify-between rounded-xl border border-slate-800 bg-slate-950 p-4 opacity-70">
                <div class="flex items-center gap-3">
                    <div>
                        <div class="text-sm font-medium">Strava</div>
                        <div class="text-xs text-slate-400">Auto-sync your activities.</div>
                    </div>
                </div>
                <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-400">Coming soon</span>
            </div>
        </div>
    </div>
</div>
