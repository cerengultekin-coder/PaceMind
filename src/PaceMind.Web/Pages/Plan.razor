@page "/plan"
@implements IDisposable
@inject PlanState PlanState
@inject NavigationManager Navigation

<PageTitle>PaceMind — Plan</PageTitle>

@if (PlanState is { HasPlan: true, Plan: { } plan })
{
    var peak = plan.Weeks.Count == 0 ? 0 : plan.Weeks.Max(w => w.TotalLoad);

    <div class="mb-6 flex items-end justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight">Your plan</h1>
            <p class="mt-1 text-slate-400">Only the first week is set; later weeks adapt to your feedback.</p>
        </div>
        <a href="onboarding" class="text-sm text-brand-300 hover:text-brand-200">Edit goal</a>
    </div>

    <div class="mb-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
        <StatCard Label="Sport" Value="@plan.Sport.ToString()" />
        <StatCard Label="Weeks" Value="@plan.TotalWeeks.ToString()" />
        <StatCard Label="Peak week load" Value="@peak.ToString()" ValueClass="text-brand-300" />
        <StatCard Label="Goal date" Value="@plan.TargetDate.ToString("dd MMM")" Hint="@plan.TargetDate.ToString("yyyy")" />
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var week in plan.Weeks)
        {
            <WeekCard Week="week" Sport="@plan.Sport.ToString()" GoalSummary="@GoalSummary()" />
        }
    </div>
}
else
{
    <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-slate-800 bg-slate-900/30 px-6 py-20 text-center">
        <h2 class="text-lg font-semibold">No plan yet</h2>
        <p class="mt-1 max-w-sm text-sm text-slate-400">Set your goal and we'll generate a periodized plan you can follow and adapt.</p>
        <button @onclick="@(() => Navigation.NavigateTo("onboarding"))"
                class="mt-6 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400">
            Set your goal →
        </button>
    </div>
}

@code {
    protected override void OnInitialized() => PlanState.Changed += StateHasChanged;

    private string GoalSummary()
    {
        var request = PlanState.LastRequest;
        if (request is null)
            return PlanState.Plan?.Sport.ToString() ?? "general fitness";

        return $"{request.TargetDistanceKm:0.#}K in {request.TargetTimeMinutes} minutes by {request.TargetDate:dd MMM yyyy}";
    }

    public void Dispose() => PlanState.Changed -= StateHasChanged;
}
