@page "/program"
@implements IDisposable
@inject PaceMindApiClient Api
@inject PlanState PlanState
@inject ActivityLog ActivityLog

<PageTitle>PaceMind — Program</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight">Your program</h1>
    <p class="mt-1 text-slate-400">One week at a time. Finish the week, log how it went, then start the next — it adapts to you.</p>
</div>

<div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
        <div class="grid gap-4">
            <div>
                <label class="mb-1.5 block text-sm text-slate-300">Target distance (km)</label>
                <input type="number" step="0.1" min="1" @bind="_form.TargetDistanceKm" class="@FieldClass" />
            </div>
            <div>
                <label class="mb-1.5 block text-sm text-slate-300">Target time (minutes)</label>
                <input type="number" min="1" @bind="_form.TargetTimeMinutes" class="@FieldClass" />
            </div>
            <div>
                <label class="mb-1.5 block text-sm text-slate-300">Target date</label>
                <input type="date" @bind="_form.TargetDate" class="@FieldClass" />
            </div>
            <div>
                <label class="mb-1.5 block text-sm text-slate-300">Max training days / week</label>
                <input type="number" min="1" max="7" @bind="_form.DaysPerWeekMax" class="@FieldClass" />
            </div>
            <div>
                <label class="mb-1.5 block text-sm text-slate-300">Blackout days</label>
                <div class="flex flex-wrap gap-2">
                    @foreach (var day in Days)
                    {
                        var active = _form.BlackoutDays.Contains(day);
                        <button type="button" @onclick="() => ToggleDay(day)"
                                class="rounded-lg border px-3 py-1.5 text-sm transition @(active
                                    ? "border-brand-500 bg-brand-500/15 text-brand-200"
                                    : "border-slate-700 text-slate-300 hover:border-slate-600")">
                            @day.ToString()[..3]
                        </button>
                    }
                </div>
            </div>
            <div>
                <label class="mb-1.5 block text-sm text-slate-300">Baseline note</label>
                <input type="text" @bind="_form.BaselineNote" placeholder="Runs 2-3x/week, longest 5K" class="@FieldClass" />
            </div>
        </div>

        @if (_error is not null)
        {
            <div class="mt-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">@_error</div>
        }

        <button @onclick="GenerateAsync" disabled="@_busy"
                class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400 disabled:opacity-60">
            @if (_busy)
            {
                <span class="h-4 w-4 animate-spin rounded-full border-2 border-slate-950/40 border-t-slate-950"></span>
                <span>Working…</span>
            }
            else
            {
                <span>@(PlanState.HasProgram ? "Restart from week 1" : "Generate week 1")</span>
            }
        </button>
    </div>

    <div class="lg:col-span-2">
        @if (PlanState is { HasProgram: true, CurrentWeek: { } week, Goal: not null })
        {
            <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
                <div class="flex items-start justify-between">
                    <div>
                        <div class="text-lg font-semibold text-brand-300">Week @week.WeekNumber</div>
                        <div class="mt-0.5 text-xs text-slate-500">Week of @week.StartDate.ToString("dd MMM yyyy")</div>
                    </div>
                    @if (week.WeekNumber >= PlanState.TotalWeeks)
                    {
                        <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs text-emerald-300">final week</span>
                    }
                </div>

                @if (_adaptationNote is not null)
                {
                    <div class="mt-4 rounded-lg border border-brand-500/30 bg-brand-500/10 p-3 text-sm text-slate-200">
                        @_adaptationNote
                        @if (_goalAtRisk)
                        {
                            <div class="mt-1 text-amber-300">Your goal may be at risk — consider adding a day or moving the date.</div>
                        }
                    </div>
                }

                <div class="mt-5 space-y-2">
                    @foreach (var workout in week.Workouts.Where(w => w.DurationMinutes is not null))
                    {
                        <div class="flex items-center gap-4 rounded-lg border border-slate-800 bg-slate-950 p-3">
                            <div class="w-12 shrink-0 text-xs font-semibold uppercase text-slate-500">@workout.DayOfWeek.ToString()[..3]</div>
                            <div class="min-w-0 flex-1">
                                <div class="font-medium @TypeColor(workout.Type)">@workout.Type</div>
                                <div class="text-xs text-slate-400">@workout.Description</div>
                            </div>
                            @if (_feelings.TryGetValue(workout.Date, out var feeling))
                            {
                                <span class="shrink-0 text-xs text-emerald-300">logged · @feeling</span>
                            }
                            else
                            {
                                <div class="flex shrink-0 flex-wrap justify-end gap-1">
                                    @foreach (var option in Feelings)
                                    {
                                        <button type="button" @onclick="() => Log(workout, option.Feeling)"
                                                class="rounded-md border border-slate-700 px-2 py-1 text-[11px] text-slate-300 transition hover:border-brand-500 hover:text-brand-200">
                                            @option.Label
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="mt-6 border-t border-slate-800 pt-5">
                    @if (week.WeekNumber < PlanState.TotalWeeks)
                    {
                        <div class="flex items-center gap-3">
                            <button @onclick="AdvanceAsync" disabled="@_busy"
                                    class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400 disabled:opacity-60">
                                @if (_busy)
                                {
                                    <span class="h-4 w-4 animate-spin rounded-full border-2 border-slate-950/40 border-t-slate-950"></span>
                                    <span>Building next week…</span>
                                }
                                else
                                {
                                    <span>Finish week &amp; start week @(week.WeekNumber + 1)</span>
                                }
                            </button>
                            <span class="text-xs text-slate-500">@_feelings.Count logged</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-sm text-emerald-300">This is your final week — finish strong. Good luck on your goal!</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="flex h-full flex-col items-center justify-center rounded-2xl border border-dashed border-slate-800 bg-slate-900/30 px-6 py-20 text-center">
                <h2 class="text-lg font-semibold">No program yet</h2>
                <p class="mt-1 max-w-sm text-sm text-slate-400">Fill in your goal and generate week 1. You'll get just this week's sessions; finish it, then start the next.</p>
            </div>
        }
    </div>
</div>

@code {
    private static readonly DayOfWeek[] Days =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday,
        DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday,
    ];

    private static readonly (string Label, string Feeling)[] Feelings =
    [
        ("Easy", "Easy"),
        ("OK", "Just right"),
        ("Hard", "Too hard"),
        ("Pain", "Pain"),
        ("Skip", "Skipped"),
    ];

    private const string FieldClass =
        "w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 outline-none focus:border-brand-500";

    private readonly FormModel _form = new();
    private readonly Dictionary<DateOnly, string> _feelings = [];
    private bool _busy;
    private string? _error;
    private string? _adaptationNote;
    private bool _goalAtRisk;

    protected override void OnInitialized() => PlanState.Changed += StateHasChanged;

    private void ToggleDay(DayOfWeek day)
    {
        if (!_form.BlackoutDays.Remove(day))
            _form.BlackoutDays.Add(day);
    }

    private PlanPreviewRequest BuildGoal() => new(
        _form.TargetDistanceKm,
        _form.TargetTimeMinutes,
        DateOnly.FromDateTime(_form.TargetDate),
        _form.DaysPerWeekMax,
        [.. _form.BlackoutDays],
        _form.BaselineNote);

    private async Task GenerateAsync()
    {
        _busy = true;
        _error = null;
        _adaptationNote = null;
        _goalAtRisk = false;

        try
        {
            var goal = BuildGoal();
            var response = await Api.GetWeekAsync(new PlanWeekRequest(goal, 1));
            _feelings.Clear();
            PlanState.SetWeek(goal, response.StartDate, response.TotalWeeks, response.Week);
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AdvanceAsync()
    {
        if (PlanState is not { CurrentWeek: { } week, Goal: { } goal })
            return;

        _busy = true;
        _error = null;

        var feedback = week.Workouts
            .Where(w => w.DurationMinutes is not null && _feelings.ContainsKey(w.Date))
            .Select(w => ToFeedback(w.DayOfWeek, _feelings[w.Date]))
            .ToList();

        try
        {
            var response = await Api.GetWeekAsync(
                new PlanWeekRequest(goal, week.WeekNumber + 1, PlanState.StartDate, feedback));
            _feelings.Clear();
            _adaptationNote = response.AdaptationSummary;
            _goalAtRisk = response.GoalAtRisk;
            PlanState.SetWeek(goal, response.StartDate, response.TotalWeeks, response.Week);
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Log(PlanWorkoutDto workout, string feeling)
    {
        _feelings[workout.Date] = feeling;
        ActivityLog.Add(new ActivityEntry(
            DateTimeOffset.Now, PlanState.Goal?.Sport.ToString() ?? "Running",
            workout.DayOfWeek, workout.Type, workout.DurationMinutes, feeling));
    }

    private static SessionFeedbackInput ToFeedback(DayOfWeek day, string feeling) => feeling switch
    {
        "Easy" => new(day, FeedbackOutcome.Completed, Difficulty.Easy),
        "Just right" => new(day, FeedbackOutcome.Completed, Difficulty.JustRight),
        "Too hard" => new(day, FeedbackOutcome.Completed, Difficulty.TooHard),
        "Pain" => new(day, FeedbackOutcome.Completed, Difficulty.Pain),
        _ => new(day, FeedbackOutcome.Skipped, SkipReason: SkipReason.Other),
    };

    private static string TypeColor(string type) => type switch
    {
        "Easy" => "text-easy",
        "Long" => "text-long",
        "Tempo" => "text-tempo",
        "Interval" => "text-interval",
        _ => "text-slate-400",
    };

    public void Dispose() => PlanState.Changed -= StateHasChanged;

    private sealed class FormModel
    {
        public double TargetDistanceKm { get; set; } = 10;
        public int TargetTimeMinutes { get; set; } = 50;
        public DateTime TargetDate { get; set; } = DateTime.Today.AddDays(84);
        public int DaysPerWeekMax { get; set; } = 4;
        public HashSet<DayOfWeek> BlackoutDays { get; } = [];
        public string BaselineNote { get; set; } = "Runs 2-3x/week, longest 5K";
    }
}
