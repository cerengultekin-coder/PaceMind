@page "/coach"

<PageTitle>PaceMind — Coach</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight">Talk to your coach</h1>
    <p class="mt-1 text-slate-400">Ask why a week looks the way it does — or tell it what changed.</p>
</div>

<div class="flex h-[60vh] flex-col rounded-2xl border border-slate-800 bg-slate-900/40">
    <div class="flex-1 space-y-4 overflow-y-auto p-6">
        @foreach (var message in _messages)
        {
            <div class="flex @(message.FromCoach ? "justify-start" : "justify-end")">
                <div class="max-w-md rounded-2xl px-4 py-2.5 text-sm @(message.FromCoach
                        ? "bg-slate-800 text-slate-100"
                        : "bg-brand-500 text-slate-950")">
                    @message.Text
                </div>
            </div>
        }
    </div>

    <div class="border-t border-slate-800 p-4">
        <div class="flex items-center gap-3">
            <input type="text" @bind="_draft" @bind:event="oninput" @onkeydown="OnKeyDown"
                   placeholder="Why is this week so light?"
                   class="flex-1 rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm outline-none focus:border-brand-500" />
            <button @onclick="Send" disabled="@string.IsNullOrWhiteSpace(_draft)"
                    class="rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400 disabled:opacity-50">
                Send
            </button>
        </div>
        <p class="mt-2 text-xs text-slate-500">Live coaching replies arrive with the AI integration — this is a preview.</p>
    </div>
</div>

@code {
    private readonly List<ChatLine> _messages =
    [
        new(true, "Hi! I'm your coach. Ask me anything about your plan."),
        new(false, "Why is week 4 lighter?"),
        new(true, "Week 4 is a recovery week — easing the load lets your body absorb the previous build before we ramp again."),
    ];

    private string _draft = string.Empty;

    private void Send()
    {
        if (string.IsNullOrWhiteSpace(_draft))
            return;

        _messages.Add(new ChatLine(false, _draft.Trim()));
        _messages.Add(new ChatLine(true, "Got it — live answers are coming with the AI coach. For now your message is noted."));
        _draft = string.Empty;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Send();
    }

    private sealed record ChatLine(bool FromCoach, string Text);
}
