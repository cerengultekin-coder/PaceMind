@page "/"
@implements IDisposable
@inject PlanState PlanState
@inject NavigationManager Navigation

<PageTitle>PaceMind — Dashboard</PageTitle>

<div class="overflow-hidden rounded-2xl border border-slate-800 bg-gradient-to-br from-brand-500/20 via-slate-900/40 to-transparent p-8">
    <div class="text-sm font-medium text-brand-300">Welcome back</div>
    <h1 class="mt-1 text-3xl font-bold tracking-tight">Your coach adapts to you.</h1>
    <p class="mt-2 max-w-xl text-slate-300">
        Set a goal and PaceMind builds a periodized plan. After every session it rewrites the
        weeks ahead around how you actually felt — and tells you why.
    </p>

    @if (!PlanState.HasPlan)
    {
        <button @onclick="GoToOnboarding"
                class="mt-6 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400">
            Set your goal →
        </button>
    }
    else
    {
        <button @onclick="GoToPlan"
                class="mt-6 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400">
            View your plan →
        </button>
    }
</div>

@if (PlanState is { HasPlan: true, Plan: { } plan })
{
    var thisWeek = plan.Weeks.FirstOrDefault();
    var nextSession = thisWeek?.Workouts.FirstOrDefault(w => w.DurationMinutes is not null);

    <div class="mt-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
        <StatCard Label="Goal" Value="@($"{plan.Sport}")" Hint="@($"by {plan.TargetDate:dd MMM yyyy}")" />
        <StatCard Label="Plan length" Value="@($"{plan.TotalWeeks} wk")" Hint="periodized to peak + taper" />
        <StatCard Label="This week load" Value="@($"{thisWeek?.TotalLoad ?? 0}")" ValueClass="text-brand-300" Hint="training load units" />
        <StatCard Label="Next session"
                  Value="@(nextSession is null ? "Rest" : nextSession.Type)"
                  Hint="@(nextSession is null ? "recovery" : $"{nextSession.DurationMinutes} min")" />
    </div>

    <div class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-lg font-semibold">This week</h2>
            <a href="plan" class="text-sm text-brand-300 hover:text-brand-200">Full plan →</a>
        </div>
        @if (thisWeek is not null)
        {
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 lg:grid-cols-7">
                @foreach (var workout in thisWeek.Workouts)
                {
                    <div class="flex min-h-20 flex-col gap-1 rounded-lg border border-slate-800 bg-slate-950 p-2">
                        <div class="text-[11px] uppercase tracking-wide text-slate-500">@workout.DayOfWeek.ToString()[..3]</div>
                        <div class="text-sm font-semibold">@workout.Type</div>
                        <div class="text-xs text-slate-400">@(workout.DurationMinutes is { } min ? $"{min} min" : "—")</div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
            <h3 class="font-semibold">Tell us your goal</h3>
            <p class="mt-1 text-sm text-slate-400">Distance, target time, and the days you can train.</p>
        </div>
        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
            <h3 class="font-semibold">Get a smart plan</h3>
            <p class="mt-1 text-sm text-slate-400">A periodized build with recovery weeks and a taper.</p>
        </div>
        <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
            <h3 class="font-semibold">It adapts</h3>
            <p class="mt-1 text-sm text-slate-400">Feedback reshapes the weeks ahead — and explains why.</p>
        </div>
    </div>
}

@code {
    protected override void OnInitialized() => PlanState.Changed += StateHasChanged;

    private void GoToOnboarding() => Navigation.NavigateTo("onboarding");
    private void GoToPlan() => Navigation.NavigateTo("plan");

    public void Dispose() => PlanState.Changed -= StateHasChanged;
}
