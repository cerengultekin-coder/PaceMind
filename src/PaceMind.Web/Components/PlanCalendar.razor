@if (Plan is null)
{
    <p class="text-slate-400">No plan to display.</p>
}
else
{
    <p class="mb-5 text-sm text-slate-400">
        @Plan.Sport · @Plan.TotalWeeks weeks · @Plan.StartDate.ToString("dd MMM yyyy") → @Plan.TargetDate.ToString("dd MMM yyyy")
    </p>

    @foreach (var week in Plan.Weeks)
    {
        <div class="mb-5">
            <div class="mb-2 flex items-baseline justify-between">
                <div class="font-semibold">
                    Week @week.WeekNumber
                    @if (week.IsDraft)
                    {
                        <span class="ml-2 rounded-full bg-amber-500/15 px-2 py-0.5 text-xs text-amber-300">draft</span>
                    }
                    else
                    {
                        <span class="ml-2 rounded-full bg-emerald-500/15 px-2 py-0.5 text-xs text-emerald-300">@week.Status</span>
                    }
                </div>
                <div class="text-sm text-slate-400">load @week.TotalLoad</div>
            </div>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 lg:grid-cols-7">
                @foreach (var workout in week.Workouts)
                {
                    <div class="flex min-h-24 flex-col gap-1 rounded-lg border border-slate-800 bg-slate-950 p-2">
                        <div class="text-[11px] uppercase tracking-wide text-slate-500">@workout.DayOfWeek.ToString()[..3]</div>
                        <div class="text-sm font-semibold @TypeColor(workout.Type)">@workout.Type</div>
                        <div class="text-xs text-slate-400">@(workout.DurationMinutes is { } min ? $"{min} min" : "—")</div>
                        <div class="text-xs text-slate-400">@(workout.IntensityZone is null ? "recovery" : $"{workout.IntensityZone} · {workout.Load}")</div>
                        <div class="mt-auto h-1 rounded-full @BarColor(workout.Type)" style="width:@(BarWidth(workout.Load))%"></div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter, EditorRequired] public PlanPreviewResponse? Plan { get; set; }

    private double MaxLoad =>
        Plan?.Weeks.SelectMany(w => w.Workouts).Select(x => x.Load).DefaultIfEmpty(1).Max() is { } max && max > 0 ? max : 1;

    private int BarWidth(double load) => (int)Math.Round(load / MaxLoad * 100);

    private static string TypeColor(string type) => type switch
    {
        "Easy" => "text-easy",
        "Long" => "text-long",
        "Tempo" => "text-tempo",
        "Interval" => "text-interval",
        _ => "text-rest",
    };

    private static string BarColor(string type) => type switch
    {
        "Easy" => "bg-easy",
        "Long" => "bg-long",
        "Tempo" => "bg-tempo",
        "Interval" => "bg-interval",
        _ => "bg-slate-800",
    };
}
