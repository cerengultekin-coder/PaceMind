<div class="rounded-xl border border-border bg-surface/60 p-5 transition hover:border-brand-500/40">
    <div class="text-xs font-medium uppercase tracking-wide text-muted">@Label</div>
    <div class="mt-1 text-2xl font-bold @ValueClass">@Value</div>
    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <div class="mt-1 text-xs text-muted">@Hint</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string ValueClass { get; set; } = "text-fg";
}
