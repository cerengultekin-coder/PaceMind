@inject PaceMindApiClient Api

<div class="[perspective:1200px]">
    <div class="relative h-72 w-full cursor-pointer rounded-2xl transition-transform duration-500 [transform-style:preserve-3d] @(_flipped ? "[transform:rotateY(180deg)]" : "")"
         @onclick="Flip">

        <div class="absolute inset-0 flex flex-col justify-between rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-900 to-slate-900/40 p-6 [backface-visibility:hidden]">
            <div class="flex items-start justify-between">
                <div class="text-xs font-medium uppercase tracking-wide text-slate-500">@Sport</div>
                @if (Week.IsDraft)
                {
                    <span class="rounded-full bg-amber-500/15 px-2.5 py-0.5 text-xs text-amber-300">draft</span>
                }
                else
                {
                    <span class="rounded-full bg-emerald-500/15 px-2.5 py-0.5 text-xs text-emerald-300">@Week.Status</span>
                }
            </div>
            <div>
                <div class="text-5xl font-bold tracking-tight">@Week.WeekNumber</div>
                <div class="mt-1 text-sm text-slate-400">Week of @Week.StartDate.ToString("dd MMM")</div>
            </div>
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-2xl font-bold text-brand-300">@Week.TotalLoad</div>
                    <div class="text-xs text-slate-500">training load</div>
                </div>
                <div class="text-xs text-slate-500">tap to open →</div>
            </div>
        </div>

        <div class="absolute inset-0 flex flex-col rounded-2xl border border-slate-800 bg-slate-900 p-5 [backface-visibility:hidden] [transform:rotateY(180deg)]">
            <div class="mb-2 flex items-center justify-between">
                <div class="font-semibold">Week @Week.WeekNumber</div>
                <div class="text-xs text-slate-500">load @Week.TotalLoad</div>
            </div>

            <div class="min-h-0 flex-1 space-y-1 overflow-y-auto pr-1">
                @foreach (var workout in Week.Workouts)
                {
                    <div class="flex items-center justify-between text-sm">
                        <span class="w-9 text-xs uppercase text-slate-500">@workout.DayOfWeek.ToString()[..3]</span>
                        <span class="flex-1 font-medium @TypeColor(workout.Type)">@workout.Type</span>
                        <span class="text-xs text-slate-400">@(workout.DurationMinutes is { } m ? $"{m} min" : "—")</span>
                    </div>
                }
            </div>

            @if (_comment is not null)
            {
                <div class="mt-2 rounded-lg border border-brand-500/30 bg-brand-500/10 p-2 text-xs text-slate-200">@_comment</div>
            }

            <div class="mt-2 flex items-center gap-2" @onclick:stopPropagation="true">
                <button @onclick="AskAiAsync" disabled="@_loading"
                        class="inline-flex items-center gap-1.5 rounded-lg bg-brand-500 px-3 py-1.5 text-xs font-semibold text-slate-950 transition hover:bg-brand-400 disabled:opacity-60">
                    @if (_loading)
                    {
                        <span class="h-3 w-3 animate-spin rounded-full border-2 border-slate-950/40 border-t-slate-950"></span>
                        <span>Thinking…</span>
                    }
                    else
                    {
                        <span>✨ Ask AI</span>
                    }
                </button>
                <a href="feedback" class="text-xs text-slate-400 hover:text-slate-200" @onclick:stopPropagation="true">Give feedback →</a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PlanWeekDto Week { get; set; } = default!;
    [Parameter, EditorRequired] public string Sport { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string GoalSummary { get; set; } = string.Empty;

    private bool _flipped;
    private bool _loading;
    private string? _comment;

    private void Flip() => _flipped = !_flipped;

    private async Task AskAiAsync()
    {
        _loading = true;
        try
        {
            var response = await Api.CommentOnWeekAsync(new CoachCommentRequest(Sport, GoalSummary, Week));
            _comment = response.Reply;
        }
        catch (ApiException ex)
        {
            _comment = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string TypeColor(string type) => type switch
    {
        "Easy" => "text-easy",
        "Long" => "text-long",
        "Tempo" => "text-tempo",
        "Interval" => "text-interval",
        _ => "text-slate-400",
    };
}
